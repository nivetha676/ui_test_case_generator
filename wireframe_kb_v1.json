    "nav_to_climate":           { "id": "nav_to_climate",           "from": "nav",     "to": "climate", "trigger": "tab_climate",         "label": "Climate tab"                },
    "nav_to_phone":             { "id": "nav_to_phone",             "from": "nav",     "to": "phone",   "trigger": "tab_phone",           "label": "Phone tab"                  },
    "climate_to_home":          { "id": "climate_to_home",          "from": "climate", "to": "home",    "trigger": "tab_home",            "label": "Home tab"                   },
    "climate_to_media":         { "id": "climate_to_media",         "from": "climate", "to": "media",   "trigger": "tab_media",           "label": "Media tab"                  },
    "climate_to_nav":           { "id": "climate_to_nav",           "from": "climate", "to": "nav",     "trigger": "tab_nav",             "label": "Nav tab"                    },
