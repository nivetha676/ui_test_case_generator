    "phone_to_home":            { "id": "phone_to_home",            "from": "phone",   "to": "home",    "trigger": "tab_home",            "label": "Home tab"                   },
    "phone_to_media":           { "id": "phone_to_media",           "from": "phone",   "to": "media",   "trigger": "tab_media",           "label": "Media tab"                  },
